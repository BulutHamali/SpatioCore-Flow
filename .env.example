# ── LiteLLM / Model provider ─────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
LITELLM_MODEL=claude-sonnet-4-6          # default routing target

# ── PostgreSQL audit trail ────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=spatiocoreflow
POSTGRES_USER=scf_user
POSTGRES_PASSWORD=changeme

# ── ChromaDB vector store ─────────────────────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_COLLECTION=spatiocoreflow_kb

# ── Redis cache ───────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Pipeline thresholds ───────────────────────────────────────────────────────
BCS_PASS_THRESHOLD=0.80          # Biological Consistency Score minimum
MAX_ANALYST_RETRIES=3            # Confidence Gate loopback limit
